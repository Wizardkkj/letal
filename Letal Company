-- 🎨 CORES DOS ORES
local ORE_COLORS = {
    ["Gold Ore"] = Color3.fromRGB(255, 215, 0),
    ["Iron Ore"] = Color3.fromRGB(90, 90, 90),
    ["Jade Ore"] = Color3.fromRGB(0, 200, 100),
    ["Amber Ore"] = Color3.fromRGB(255, 140, 0),
    ["Amethyst Ore"] = Color3.fromRGB(170, 0, 255),
}

local function getOreColor(name)
    if ORE_COLORS[name] then
        return ORE_COLORS[name]
    end
    if string.find(name, "Ore") then
        return Color3.fromRGB(180,180,180)
    end
    return Color3.fromRGB(0,255,255)
end

