    espItemBtn.Text = "ESP Itens: "..(ESP_ITEMS and "ON" or "OFF")
    if not ESP_ITEMS then clearItemESP() end
end)

espMobBtn.MouseButton1Click:Connect(function()
    ESP_MONSTERS = not ESP_MONSTERS
    espMobBtn.Text = "ESP Monsters: "..(ESP_MONSTERS and "ON" or "OFF")
    if not ESP_MONSTERS then clearMonsterESP() end
end)

scanBtn.MouseButton1Click:Connect(function()
    for _,v in pairs(listFrame:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    ITEM_LIST = {}
    local folder = ws.ProcGenGenerated.ProcGenItems

    for _,item in pairs(folder:GetChildren()) do
        ITEM_LIST[item.Name] = ITEM_LIST[item.Name] or {}
        table.insert(ITEM_LIST[item.Name], item)
    end

    for name,items in pairs(ITEM_LIST) do
        local btn = newBtn(name.." ("..#items..")", 0)
        btn.Parent = listFrame

        btn.MouseButton1Click:Connect(function()
            local target = items[1]
            if target then
                plr.Character:PivotTo(target.Handle.CFrame + Vector3.new(0,3,0))
                table.remove(items,1)
                btn.Text = name.." ("..#items..")"
                if #items == 0 then btn:Destroy() end
            end
        end)
    end
end)

