-- 🔥 ESP ITEM
local function addItemESP(item)
    if ESP_CACHE[item] then return end
    if not item:FindFirstChild("Handle") then return end

    local hl = Instance.new("Highlight")
    hl.Name = "ESP"
    hl.Adornee = item.Handle
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillColor = getOreColor(item.Name)
    hl.FillTransparency = 0.7
    hl.OutlineColor = getOreColor(item.Name)
    hl.OutlineTransparency = 0
    hl.Parent = item.Handle

    ESP_CACHE[item] = hl
end

local function clearItemESP()
    for _,v in pairs(ESP_CACHE) do v:Destroy() end
    ESP_CACHE = {}
end

-- 🔥 ESP MONSTRO (FIX BIRD)
local function addMonsterESP(mob)
    if MONSTER_CACHE[mob] then return end

    local part = mob:FindFirstChild("HumanoidRootPart") or mob:FindFirstChildWhichIsA("BasePart")
    if not part then return end

    local hl = Instance.new("Highlight")
    hl.Name = "ESP"
    hl.Adornee = mob
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillColor = Color3.fromRGB(255,0,0)
    hl.FillTransparency = 0.75
    hl.OutlineColor = Color3.fromRGB(255,0,0)
    hl.OutlineTransparency = 0
    hl.Parent = mob

    MONSTER_CACHE[mob] = hl
end

local function clearMonsterESP()
    for _,v in pairs(MONSTER_CACHE) do v:Destroy() end
    MONSTER_CACHE = {}
end

-- 🔁 LOOP AUTOMÁTICO ITENS
task.spawn(function()
    while true do
        if ESP_ITEMS then
            local folder = ws:FindFirstChild("ProcGenGenerated")
            if folder and folder:FindFirstChild("ProcGenItems") then
                for _,item in pairs(folder.ProcGenItems:GetChildren()) do
                    addItemESP(item)
                end
            end
        end
        task.wait(1)
    end
end)

-- 🔁 LOOP MONSTROS
task.spawn(function()
    while true do
        if ESP_MONSTERS then
            for _,mob in pairs(ws.Monsters:GetChildren()) do
                addMonsterESP(mob)
            end

            -- força BirdMonster
            if ws.Monsters:FindFirstChild("BirdMonster") then
                addMonsterESP(ws.Monsters.BirdMonster)
            end
        end
        task.wait(1)
    end
end)

-- BOTÕES
espItemBtn.MouseButton1Click:Connect(function()
